# nuxt-auth-utils — encrypt session cookies (min 32 chars)
NUXT_SESSION_PASSWORD=

# Google OAuth — https://console.cloud.google.com/apis/credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Vercel Postgres — added automatically when you link a Vercel Postgres DB
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_DATABASE=
