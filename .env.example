# Public variables exposed to the browser
# Local development example values
NUXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only variables
# Never prefix secrets with NUXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
